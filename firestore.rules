rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Lead capture collections ─────────────────────────────────────────────
    // Write-only from any client (public form submissions).
    // Read is denied — use Firebase Console or Admin SDK for lead review.

    match /leads/{doc} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 256;
      allow read, update, delete: if false;
    }

    match /demo_bookings/{doc} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 256;
      allow read, update, delete: if false;
    }

    match /newsletter_subscribers/{doc} {
      allow create: if request.resource.data.keys().hasAll(['email', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 256;
      allow read, update, delete: if false;
    }

    match /investor_leads/{doc} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 256;
      allow read, update, delete: if false;
    }

    // ── Default: deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
