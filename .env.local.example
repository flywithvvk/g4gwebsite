# ─────────────────────────────────────────────────────────────────────────────
# Go4Garage — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase App Check (reCAPTCHA v3) ──────────────────────────────────────
# STATUS: App Check API enabled. Enforcement: UNENFORCED (monitors only).
#
# PRODUCTION — get reCAPTCHA v3 site key:
#   Firebase Console → App Check → web app "website" → reCAPTCHA v3 → copy site key
#   Then flip enforcement to ENFORCED in Firebase Console → App Check → APIs → Firestore
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
#
# DEVELOPMENT / CI — use a debug token (UUID4):
#   The SHA-1 fingerprints shown in Firebase Console (e.g. 1d7c5561...) are read-only.
#   Use the original UUID4 that was displayed when you CREATED the debug token.
#   Firebase Console → App Check → web app → Manage debug tokens → copy the UUID shown on creation.
#   Two debug tokens are already registered (fingerprints: 1d7c5561... and 69090902...).
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# ── Google Ads (AdWords) ────────────────────────────────────────────────────
# STATUS: Pending — create Google Ads account then fill these in
# Get from: Google Ads → Tools → Measurement → Conversions
# Format: AW-XXXXXXXXX  (the Account ID)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Individual conversion action labels (format: AW-XXXXXXXXX/AbCdEfGhIjK)
NEXT_PUBLIC_GADS_DEMO_CONVERSION=
NEXT_PUBLIC_GADS_LEAD_CONVERSION=
NEXT_PUBLIC_GADS_PRICING_CONVERSION=

# ── Google Search Console ───────────────────────────────────────────────────
# Get from: Search Console → Settings → Ownership verification → HTML tag
# Copy the content= value from the meta tag
NEXT_PUBLIC_GOOGLE_SEARCH_CONSOLE_ID=
